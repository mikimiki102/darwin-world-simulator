<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>


<VBox spacing="10"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      minHeight="530.0" minWidth="525.0"
      fx:controller="agh.ics.oop.presenter.MenuPresenter">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Konfiguracja Symulacji" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="5">
        <Label text="Szerokość mapy:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="widthField" text="20" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Wysokość mapy:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="heightField" text="20" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Startowa liczba roślin:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="startPlantCountField" text="10" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label text="Rośliny na dzień:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <TextField fx:id="plantsPerDayField" text="2" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <Label text="Energia z rośliny:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <TextField fx:id="plantEnergyField" text="15" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="4" />

        <Label text="Startowa liczba zwierząt:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
        <TextField fx:id="startAnimalCountField" text="10" prefWidth="80" GridPane.columnIndex="3" GridPane.rowIndex="0" />

        <Label text="Startowa energia:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
        <TextField fx:id="startAnimalEnergyField" text="30" prefWidth="80" GridPane.columnIndex="3" GridPane.rowIndex="1" />

        <Label text="Energia do rozmnażania:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
        <TextField fx:id="energyToReproduceField" text="20" prefWidth="80" GridPane.columnIndex="3" GridPane.rowIndex="2" />

        <Label text="Energia dla dziecka:" GridPane.columnIndex="2" GridPane.rowIndex="3" />
        <TextField fx:id="energyToChildField" text="15" prefWidth="80" GridPane.columnIndex="3" GridPane.rowIndex="3" />

        <Label text="Dzienny koszt energii:" GridPane.columnIndex="2" GridPane.rowIndex="4" />
        <TextField fx:id="energyLossPerDayField" text="1" prefWidth="80" GridPane.columnIndex="3" GridPane.rowIndex="4" />

        <Label text="Długość genomu:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
        <TextField fx:id="genomeLengthField" text="8" prefWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="6" />

        <Label text="Min. mutacji:" GridPane.columnIndex="2" GridPane.rowIndex="6" />
        <TextField fx:id="minMutationsField" text="0" prefWidth="80" GridPane.columnIndex="3" GridPane.rowIndex="6" />

        <Label text="Max. mutacji:" GridPane.columnIndex="2" GridPane.rowIndex="7" />
        <TextField fx:id="maxMutationsField" text="3" prefWidth="80" GridPane.columnIndex="3" GridPane.rowIndex="7" />
    </GridPane>

    <Separator/>

    <CheckBox fx:id="fireEnabledCheckbox" text="Włącz pożary"/>

    <GridPane hgap="10" vgap="5" fx:id="fireOptionsPane" disable="true">
    <Label text="Szansa na pożar (%):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="fireChanceField" text="5" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Czas trwania ognia:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="fireDurationField" text="3" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Strata energii w ogniu:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="fireLossField" text="20" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <Separator/>

    <Button text="Uruchom Symulację" onAction="#onStartSimulation" maxWidth="Infinity"/>
    <Label fx:id="infoLabel" />
</VBox>